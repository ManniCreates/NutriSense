rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'goal', 'isConfigured', 'createdAt', 'updatedAt']) 
             && data.email is string && data.email.size() <= 200
             && data.goal is string && data.goal.size() <= 100
             && data.isConfigured is bool
             && data.createdAt is int
             && data.updatedAt is int;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming()) && incoming().createdAt == existing().createdAt;
      
      match /meals/{mealId} {
        allow get: if isSignedIn() && isValidId(userId) && isValidId(mealId) && request.auth.uid == userId;
        allow list: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(mealId) && request.auth.uid == userId && incoming().userId == request.auth.uid;
        allow update: if isSignedIn() && isValidId(userId) && isValidId(mealId) && request.auth.uid == userId && incoming().userId == request.auth.uid;
        allow delete: if isSignedIn() && isValidId(userId) && isValidId(mealId) && request.auth.uid == userId;
      }
      
      match /progress/{progressId} {
        allow get: if isSignedIn() && isValidId(userId) && isValidId(progressId) && request.auth.uid == userId;
        allow list: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(progressId) && request.auth.uid == userId && incoming().userId == request.auth.uid;
        allow update: if isSignedIn() && isValidId(userId) && isValidId(progressId) && request.auth.uid == userId && incoming().userId == request.auth.uid;
        allow delete: if isSignedIn() && isValidId(userId) && isValidId(progressId) && request.auth.uid == userId;
      }
      
      match /savedRecipes/{recipeId} {
        allow get: if isSignedIn() && isValidId(userId) && isValidId(recipeId) && request.auth.uid == userId;
        allow list: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(recipeId) && request.auth.uid == userId && incoming().userId == request.auth.uid;
        allow update: if isSignedIn() && isValidId(userId) && isValidId(recipeId) && request.auth.uid == userId && incoming().userId == request.auth.uid;
        allow delete: if isSignedIn() && isValidId(userId) && isValidId(recipeId) && request.auth.uid == userId;
      }
    }
  }
}
